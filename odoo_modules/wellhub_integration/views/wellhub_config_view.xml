<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wellhub_config_tree" model="ir.ui.view">
        <field name="name">wellhub.config.tree</field>
        <field name="model">wellhub.config</field>
        <field name="arch" type="xml">
            <tree>
                <field name="company_id"/>
                <field name="location_id"/>
                <field name="precio_unitario_default"/>
                <field name="total_checkins"/>
                <field name="last_checkin_at"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_wellhub_config_form" model="ir.ui.view">
        <field name="name">wellhub.config.form</field>
        <field name="model">wellhub.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_webhook" string="Mostrar URL/secret webhook"
                            type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="company_id" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Credenciales API">
                            <field name="webhook_secret" password="True"/>
                            <field name="client_id"/>
                            <field name="client_secret" password="True"/>
                            <field name="location_id"/>
                            <field name="api_base_url"/>
                        </group>
                        <group string="Económico">
                            <field name="precio_unitario_default"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="partner_wellhub_id"/>
                            <field name="bank_concept_pattern"/>
                            <field name="email_alerta"/>
                        </group>
                    </group>
                    <group string="Tracking">
                        <field name="last_checkin_at" readonly="1"/>
                        <field name="last_settlement_at" readonly="1"/>
                        <field name="total_checkins" readonly="1"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wellhub_config" model="ir.actions.act_window">
        <field name="name">Configuración Wellhub</field>
        <field name="res_model">wellhub.config</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
